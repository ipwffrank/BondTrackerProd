rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSameOrg(orgId) {
      return isAuthenticated() && getUserData().organizationId == orgId;
    }

    function isAdminInOrg(orgId) {
      return isSameOrg(orgId) && getUserData().isAdmin == true;
    }

    function isHostAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/hostAdmins/$(request.auth.uid));
    }

    // Fields a user is NOT allowed to change on their own profile. Without
    // this restriction a user could set isAdmin=true on /users/{uid} and
    // grant themselves admin via getUserData().isAdmin in downstream rules.
    function userSelfEditAllowed() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(['name', 'email', 'consentGiven', 'consentTimestamp',
                  'consentPolicyVersion', 'aiTranscriptConsent',
                  'aiTranscriptConsentTimestamp', 'lastLogin', 'updatedAt',
                  'preferences']);
    }

    // ============================================
    // HOST ADMINS COLLECTION
    // ============================================

    match /hostAdmins/{uid} {
      // Host admins can list all; authenticated users can check their own status
      allow read: if isHostAdmin() || (isAuthenticated() && request.auth.uid == uid);
      // Only existing host admins can add/remove other host admins
      allow write: if isHostAdmin();
    }

    // ============================================
    // DEMO REQUESTS COLLECTION
    // ============================================

    match /demoRequests/{requestId} {
      // Public form submissions (unauthenticated)
      allow create: if true;
      // Only host admins can read, update, delete
      allow read, update, delete: if isHostAdmin();
    }

    // ============================================
    // ORGANIZATIONS COLLECTION
    // ============================================

    match /organizations/{orgId} {
      // Org members or host admins can read
      allow read: if isSameOrg(orgId) || isHostAdmin();

      // Any authenticated user can create an organization (for first-time signup)
      allow create: if isAuthenticated();

      // Host admins can update anything on the org doc.
      allow update: if isHostAdmin();

      // Org admins can update most settings BUT cannot touch the pilot
      // fields — those control how long they get free access and must
      // only be changeable by a host admin (otherwise the trial is
      // self-extendable).
      allow update: if isAdminInOrg(orgId)
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['pilotStartedAt', 'pilotEndAt', 'pilotDurationDays', 'pilotStatus', 'pilotRemindersSent']);

      // Prevent deletion of organizations
      allow delete: if false;
    }
    
    // ============================================
    // USERS COLLECTION (Top-level for team management)
    // ============================================
    
    match /users/{userId} {
      // Users can read their own profile, or profiles within same org
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        getUserData().organizationId == resource.data.organizationId ||
        isHostAdmin()
      );

      // Users can create their own profile during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Admins can create phantom/demo users in their org
      allow create: if isAuthenticated()
        && getUserData().isAdmin == true
        && request.resource.data.organizationId == getUserData().organizationId;
      
      // Users can update their own profile, but ONLY non-privileged fields.
      // isAdmin / organizationId / role must be changed by an org admin via
      // the rule below (or by a host admin).
      allow update: if request.auth.uid == userId && userSelfEditAllowed();

      // Admins can update other users in their organization (for role changes)
      allow update: if isAuthenticated()
        && getUserData().isAdmin == true
        && get(/databases/$(database)/documents/users/$(userId)).data.organizationId == getUserData().organizationId;

      // Host admins can update any user (role/org changes from admin portal)
      allow update: if isHostAdmin();

      // Admins can delete other users in their organization (but not themselves)
      allow delete: if isAuthenticated()
        && getUserData().isAdmin == true
        && get(/databases/$(database)/documents/users/$(userId)).data.organizationId == getUserData().organizationId
        && userId != request.auth.uid;

      // Host admins can delete any user except themselves (admin portal).
      allow delete: if isHostAdmin() && userId != request.auth.uid;
    }

    // ============================================
    // ORGANIZATION USERS SUB-COLLECTION
    // ============================================

    match /organizations/{orgId}/users/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;

      // Org members or host admins can read all users in org
      allow read: if isSameOrg(orgId) || isHostAdmin();

      // Users can create their own profile during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // Admins can create phantom/demo users in their org
      allow create: if isAdminInOrg(orgId);

      // Host admins can create users in any org (used by the admin portal
      // when moving a user to a different org — setDoc-merge hits the
      // create branch if the sub-collection doc doesn't exist yet).
      allow create: if isHostAdmin();

      // Users can update their own profile (non-privileged fields only —
      // mirrors the guard on /users/{uid}).
      allow update: if isAuthenticated() && request.auth.uid == userId && userSelfEditAllowed();

      // Admins can update other users in their organization
      allow update: if isAdminInOrg(orgId);

      // Host admins can update any user across orgs (admin portal).
      allow update: if isHostAdmin();

      // Admins can delete other users (but not themselves)
      allow delete: if isAdminInOrg(orgId) && userId != request.auth.uid;

      // Host admins can delete any user except themselves (admin portal —
      // used when reassigning a user to a new org, which removes the
      // doc from the previous org's sub-collection).
      allow delete: if isHostAdmin() && userId != request.auth.uid;
    }

    // ============================================
    // ACTIVITIES SUB-COLLECTION
    // ============================================

    match /organizations/{orgId}/activities/{activityId} {
      // Read visibility is scoped by sales coverage (see also Dashboard
      // client-side filter — this rule makes the restriction server-side):
      //   - Org admins and host admins see everything
      //   - Other org members only see activities where their user name is
      //     listed in the denormalized `coverageUsers` array (primary or
      //     backup coverage of the client, stamped at write time)
      // Non-admin queries MUST include where('coverageUsers', 'array-contains',
      // <my name>) — otherwise the rule rejects the query. See Activities /
      // Dashboard / Analytics for the admin-aware query pattern.
      allow read: if isAdminInOrg(orgId)
        || isHostAdmin()
        || (isSameOrg(orgId)
            && 'coverageUsers' in resource.data
            && resource.data.coverageUsers.hasAny([getUserData().name]));

      // Org members can create activities (spec: anyone can log a trade for
      // any client, even clients they don't cover). The write handler is
      // responsible for stamping coverageUsers from the client record so the
      // read rule above can gate visibility.
      allow create: if isSameOrg(orgId);

      // Org members can update activities (for inline status/price edits)
      allow update: if isSameOrg(orgId);

      // Only admins can delete activities
      allow delete: if isAdminInOrg(orgId);
    }
    
    // ============================================
    // CLIENTS SUB-COLLECTION
    // ============================================
    
    match /organizations/{orgId}/clients/{clientId} {
      // Org members or host admins can read (host admin for aggregate monitoring only)
      allow read: if isSameOrg(orgId) || isHostAdmin();

      // Org members can create clients
      allow create: if isSameOrg(orgId);

      // Only admins can update or delete clients
      allow update, delete: if isAdminInOrg(orgId);

      // Contacts sub-collection (people within a client institution)
      match /contacts/{contactId} {
        allow read: if isSameOrg(orgId) || isHostAdmin();
        allow create: if isSameOrg(orgId);
        allow update, delete: if isAdminInOrg(orgId);
      }
    }
    
    // ============================================
    // NEW ISSUES SUB-COLLECTION (Pipeline)
    // ============================================

    match /organizations/{orgId}/newIssues/{issueId} {
      allow read: if isSameOrg(orgId) || isHostAdmin();
      allow create: if isSameOrg(orgId);
      allow update: if isSameOrg(orgId);
      allow delete: if isAdminInOrg(orgId);
    }

    // ============================================
    // ORDER BOOKS SUB-COLLECTION (Pipeline)
    // ============================================

    match /organizations/{orgId}/orderBooks/{orderId} {
      allow read: if isSameOrg(orgId) || isHostAdmin();
      allow create: if isSameOrg(orgId);
      allow update: if isSameOrg(orgId);
      allow delete: if isAdminInOrg(orgId);
    }

    // ============================================
    // CLIENT FEEDBACK SUB-COLLECTION (Pipeline)
    // ============================================

    match /organizations/{orgId}/clientFeedback/{feedbackId} {
      allow read: if isSameOrg(orgId) || isHostAdmin();
      allow create: if isSameOrg(orgId);
      allow update: if isSameOrg(orgId);
      allow delete: if isAdminInOrg(orgId) || (isAuthenticated() && resource.data.createdBy == getUserData().name);
    }

    // ============================================
    // PIPELINE SUB-COLLECTION
    // ============================================

    match /organizations/{orgId}/pipeline/{issueId} {
      // Org members or host admins can read (host admin for aggregate monitoring only)
      allow read: if isSameOrg(orgId) || isHostAdmin();
      
      // Org members can create pipeline issues
      allow create: if isSameOrg(orgId);
      
      // Org members can update pipeline issues (for drag-drop status changes)
      allow update: if isSameOrg(orgId);
      
      // Only admins can delete pipeline issues
      allow delete: if isAdminInOrg(orgId);
    }
    
    // ============================================
    // INVITATIONS SUB-COLLECTION (Team Management)
    // ============================================

    match /organizations/{orgId}/invitations/{invitationId} {
      // Read is limited to the invitee (who needs to load their invitation
      // during accept) or members of the target org. Previously any
      // authenticated user could enumerate invitations across every org,
      // leaking email/role/status.
      //
      // Unauthenticated reads are allowed ONLY for pending invitations and
      // ONLY when the caller already knows the invitation ID. The /accept-
      // invite flow needs this: a new user clicking the email link hasn't
      // signed up yet, so they're anonymous when the page tries to load
      // their invitation. The invitation ID is a Firestore auto-generated
      // 20-char ID (unguessable), so this doesn't enable enumeration —
      // someone needs the exact ID + orgId to read anything, which they
      // only get from the invitation email.
      allow read: if isSameOrg(orgId)
        || isHostAdmin()
        || (isAuthenticated() && resource.data.email == request.auth.token.email)
        || (!isAuthenticated() && resource.data.status == 'pending');

      // Admins or host admins can create invitations
      allow create: if isAdminInOrg(orgId) || isHostAdmin();

      // Admins can update freely. An invitee can only flip their own
      // invitation to accepted (status + acceptedAt) — they must not be
      // able to change role/org/email and escalate themselves.
      allow update: if isAdminInOrg(orgId) ||
        (isAuthenticated()
          && resource.data.email == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'acceptedAt'])
          && request.resource.data.status == 'accepted');

      // Only admins can delete invitations
      allow delete: if isAdminInOrg(orgId);
    }
    
    // ============================================
    // AUDIT LOGS SUB-COLLECTION
    // ============================================

    match /organizations/{orgId}/auditLogs/{logId} {
      // Only org admins and host admins can read audit logs
      allow read: if isAdminInOrg(orgId) || isHostAdmin();

      // Org members can create audit log entries
      allow create: if isSameOrg(orgId);

      // Audit logs are immutable — no updates or deletes allowed
      allow update: if false;
      allow delete: if false;
    }

    // ============================================
    // TRANSCRIPT UPLOADS SUB-COLLECTION
    // ============================================

    match /organizations/{orgId}/transcriptUploads/{uploadId} {
      allow read: if isSameOrg(orgId) || isHostAdmin();
      allow create: if isSameOrg(orgId);
      allow delete: if isAdminInOrg(orgId);
    }

    // ============================================
    // AI CORRECTIONS SUB-COLLECTION (few-shot learning)
    // ============================================

    match /organizations/{orgId}/aiCorrections/{correctionId} {
      allow read: if isSameOrg(orgId) || isHostAdmin();
      allow create: if isSameOrg(orgId);
      allow delete: if isAdminInOrg(orgId);
    }

    // ============================================
    // MAINTENANCE COLLECTION (system-wide notices)
    // ============================================

    match /maintenance/{maintenanceId} {
      // All authenticated users can read (for banner display)
      allow read: if isAuthenticated();
      // Only host admins can create, update, delete
      allow create, update, delete: if isHostAdmin();
    }

    // ============================================
    // ARTIFACTS COLLECTION (if used)
    // ============================================
    
    match /artifacts/{artifactId} {
      // Scoped to owner only (both existing reads/writes and new artifacts
      // must carry the caller's UID as ownerId).
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerId;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
    }
  }
}
