# Firebase Configuration
# Copy this file to .env.local and fill in your values from the Firebase Console:
# https://console.firebase.google.com → Project Settings → Your Apps → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Netlify Function Environment Variables (set in Netlify dashboard, not here)
# RESEND_API_KEY=         (for send-invite and password-changed-notify functions)
# ANTHROPIC_API_KEY=      (for analyze-transcript function)
